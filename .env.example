# Venice AI API (used by the backend for query translation/reasoning)
VENICE_API_KEY=
VENICE_API_BASE_URL=https://api.venice.ai/api/v1

# Schema introspection sandbox (see docker-compose.yml) - defaults below already
# match docker-compose.yml, so these only need overriding if you change that file.
PROMETHEUS_URL=http://localhost:9090
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=dev-token-please-change
INFLUXDB_BUCKET=ecommerce
