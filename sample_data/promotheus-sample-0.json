{
  "panels": [
    {
      "id": 323,
      "title": "Pressure",
      "type": "bargauge",
      "description": "Resource pressure via PSI",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "rate(node_pressure_cpu_waiting_seconds_total{instance=\"$node\",job=\"$job\"}[$__rate_interval])", "legendFormat": "CPU"},
        {"refId": "B", "expr": "rate(node_pressure_memory_waiting_seconds_total{instance=\"$node\",job=\"$job\"}[$__rate_interval])", "legendFormat": "Mem"},
        {"refId": "C", "expr": "rate(node_pressure_io_waiting_seconds_total{instance=\"$node\",job=\"$job\"}[$__rate_interval])", "legendFormat": "I/O"},
        {"refId": "D", "expr": "rate(node_pressure_irq_stalled_seconds_total{instance=\"$node\",job=\"$job\"}[$__rate_interval])", "legendFormat": "Irq"}
      ]
    },
    {
      "id": 20,
      "title": "CPU Busy",
      "type": "gauge",
      "description": "Overall CPU busy percentage (averaged across all cores)",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"$node\",job=\"$job\"}[$__rate_interval])))"}
      ]
    },
    {
      "id": 155,
      "title": "Sys Load",
      "type": "gauge",
      "description": "System load over all CPU cores together",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "scalar(node_load1{instance=\"$node\",job=\"$job\"}) * 100 / count(count(node_cpu_seconds_total{instance=\"$node\",job=\"$job\"}) by (cpu))"}
      ]
    },
    {
      "id": 16,
      "title": "RAM Used",
      "type": "gauge",
      "description": "Real RAM usage excluding cache and reclaimable memory",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "B", "expr": "clamp_min((1 - (node_memory_MemAvailable_bytes{instance=\"$node\", job=\"$job\"} / node_memory_MemTotal_bytes{instance=\"$node\", job=\"$job\"})) * 100, 0)"}
      ]
    },
    {
      "id": 154,
      "title": "Root FS Used",
      "type": "gauge",
      "description": "Used Root FS",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "(\n  (node_filesystem_size_bytes{instance=\"$node\", job=\"$job\", mountpoint=\"/\", fstype!=\"rootfs\"}\n   - node_filesystem_avail_bytes{instance=\"$node\", job=\"$job\", mountpoint=\"/\", fstype!=\"rootfs\"})\n  / node_filesystem_size_bytes{instance=\"$node\", job=\"$job\", mountpoint=\"/\", fstype!=\"rootfs\"}\n) * 100\n"}
      ]
    },
    {
      "id": 14,
      "title": "CPU Cores",
      "type": "stat",
      "description": "",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "count(count(node_cpu_seconds_total{instance=\"$node\",job=\"$job\"}) by (cpu))"}
      ]
    },
    {
      "id": 15,
      "title": "Uptime",
      "type": "stat",
      "description": "",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "node_time_seconds{instance=\"$node\",job=\"$job\"} - node_boot_time_seconds{instance=\"$node\",job=\"$job\"}"}
      ]
    },
    {
      "id": 77,
      "title": "CPU Basic",
      "type": "timeseries",
      "description": "CPU time spent busy vs idle, split by activity type",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "avg(rate(node_cpu_seconds_total{instance=\"$node\",job=\"$job\", mode=\"system\"}[$__rate_interval]))", "legendFormat": "Busy System"},
        {"refId": "B", "expr": "avg(rate(node_cpu_seconds_total{instance=\"$node\",job=\"$job\", mode=\"user\"}[$__rate_interval]))", "legendFormat": "Busy User"},
        {"refId": "C", "expr": "avg(rate(node_cpu_seconds_total{instance=\"$node\",job=\"$job\", mode=\"iowait\"}[$__rate_interval]))", "legendFormat": "Busy Iowait"},
        {"refId": "F", "expr": "avg(rate(node_cpu_seconds_total{instance=\"$node\",job=\"$job\", mode=\"idle\"}[$__rate_interval]))", "legendFormat": "Idle"}
      ]
    },
    {
      "id": 78,
      "title": "Memory Basic",
      "type": "timeseries",
      "description": "RAM and swap usage overview, including caches",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "node_memory_MemTotal_bytes{instance=\"$node\",job=\"$job\"}", "legendFormat": "Total"},
        {"refId": "B", "expr": "node_memory_MemTotal_bytes{instance=\"$node\",job=\"$job\"} - node_memory_MemFree_bytes{instance=\"$node\",job=\"$job\"} - (node_memory_Cached_bytes{instance=\"$node\",job=\"$job\"} + node_memory_Buffers_bytes{instance=\"$node\",job=\"$job\"} + node_memory_SReclaimable_bytes{instance=\"$node\",job=\"$job\"})", "legendFormat": "Used"},
        {"refId": "D", "expr": "node_memory_MemFree_bytes{instance=\"$node\",job=\"$job\"}", "legendFormat": "Free"}
      ]
    },
    {
      "id": 74,
      "title": "Network Traffic Basic",
      "type": "timeseries",
      "description": "Per-interface network traffic (receive and transmit) in bits per second",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "rate(node_network_receive_bytes_total{instance=\"$node\",job=\"$job\"}[$__rate_interval])*8", "legendFormat": "Rx {{device}}"},
        {"refId": "B", "expr": "rate(node_network_transmit_bytes_total{instance=\"$node\",job=\"$job\"}[$__rate_interval])*8", "legendFormat": "Tx {{device}}"}
      ]
    },
    {
      "id": 152,
      "title": "Disk Space Used Basic",
      "type": "timeseries",
      "description": "Percentage of filesystem space used for each mounted device",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "((node_filesystem_size_bytes{instance=\"$node\", job=\"$job\", device!~'rootfs'} - node_filesystem_avail_bytes{instance=\"$node\", job=\"$job\", device!~'rootfs'}) / node_filesystem_size_bytes{instance=\"$node\", job=\"$job\", device!~'rootfs'}) * 100", "legendFormat": "{{mountpoint}}"}
      ]
    },
    {
      "id": 7,
      "title": "System Load",
      "type": "timeseries",
      "description": "System load average over 1, 5, and 15 minutes. Reflects the number of active or waiting processes. Values above CPU core count may indicate overload",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "node_load1{instance=\"$node\",job=\"$job\"}", "legendFormat": "Load 1m"},
        {"refId": "B", "expr": "node_load5{instance=\"$node\",job=\"$job\"}", "legendFormat": "Load 5m"},
        {"refId": "C", "expr": "node_load15{instance=\"$node\",job=\"$job\"}", "legendFormat": "Load 15m"},
        {"refId": "D", "expr": "count(count(node_cpu_seconds_total{instance=\"$node\",job=\"$job\"}) by (cpu))", "legendFormat": "CPU Core Count"}
      ]
    },
    {
      "id": 37,
      "title": "Disk Average Wait Time",
      "type": "timeseries",
      "description": "Average time for requests issued to the device to be served. This includes the time spent by the requests in queue and the time spent servicing them.",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "(rate(node_disk_reads_completed_total{instance=\"$node\",job=\"$job\"}[$__rate_interval]) > bool 0) * (rate(node_disk_read_time_seconds_total{instance=\"$node\",job=\"$job\"}[$__rate_interval]) / rate(node_disk_reads_completed_total{instance=\"$node\",job=\"$job\"}[$__rate_interval]))", "legendFormat": "{{device}} - Read"},
        {"refId": "B", "expr": "(rate(node_disk_writes_completed_total{instance=\"$node\",job=\"$job\"}[$__rate_interval]) > bool 0) * (rate(node_disk_write_time_seconds_total{instance=\"$node\",job=\"$job\"}[$__rate_interval]) / rate(node_disk_writes_completed_total{instance=\"$node\",job=\"$job\"}[$__rate_interval]))", "legendFormat": "{{device}} - Write"}
      ]
    },
    {
      "id": 8,
      "title": "Context Switches / Interrupts",
      "type": "timeseries",
      "description": "Per-second rate of context switches and hardware interrupts. High values may indicate intense CPU or I/O activity",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "rate(node_context_switches_total{instance=\"$node\",job=\"$job\"}[$__rate_interval])", "legendFormat": "Context switches"},
        {"refId": "B", "expr": "rate(node_intr_total{instance=\"$node\",job=\"$job\"}[$__rate_interval])", "legendFormat": "Interrupts"}
      ]
    },
    {
      "id": 44,
      "title": "Filesystem in ReadOnly / Error",
      "type": "timeseries",
      "description": "Indicates filesystems mounted in read-only mode or reporting device-level I/O errors.",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "node_filesystem_readonly{instance=\"$node\",job=\"$job\",device!~'rootfs'}", "legendFormat": "{{mountpoint}} - ReadOnly"},
        {"refId": "B", "expr": "node_filesystem_device_error{instance=\"$node\",job=\"$job\",device!~'rootfs',fstype!~'tmpfs'}", "legendFormat": "{{mountpoint}} - Device error"}
      ]
    },
    {
      "id": 85,
      "title": "TCP Connections",
      "type": "timeseries",
      "description": "Number of currently established TCP connections and the system's max supported limit. On Linux, MaxConn may return -1 to indicate a dynamic/unlimited configuration",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "targets": [
        {"refId": "A", "expr": "node_netstat_Tcp_CurrEstab{instance=\"$node\",job=\"$job\"}", "legendFormat": "Current Connections"},
        {"refId": "B", "expr": "node_netstat_Tcp_MaxConn{instance=\"$node\",job=\"$job\"}", "legendFormat": "Max Connections"}
      ]
    }
  ],
  "title": "Node Exporter Full (trimmed for hackathon demo)",
  "uid": "rYdddlPWk-trimmed",
  "tags": ["linux"],
  "templating": {
    "list": [
      {"name": "ds_prometheus", "type": "datasource", "query": "prometheus"},
      {"name": "job", "type": "query"},
      {"name": "nodename", "type": "query"},
      {"name": "node", "type": "query"}
    ]
  },
  "_source_note": "Trimmed from the real 'Node Exporter Full' community dashboard (Grafana ID 1860, github.com/rfmoz/grafana-dashboards) from 150+ panels down to 15, selected for a mix of simple single-query gauges and more complex multi-query/label-filtered/aggregation timeseries panels, for hackathon demo purposes."
}